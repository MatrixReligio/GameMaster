# macOS
.DS_Store
*.swp

# Xcode
build/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcuserstate
*.moved-aside
*.pbxuser
!default.pbxuser

# XcodeGen generates the project; do not commit it — EXCEPT the SwiftPM
# Package.resolved, which pins Sparkle to a reviewed revision (supply-chain
# guard). Re-including a file under an ignored dir requires whitelisting
# every parent level.
GameMaster.xcodeproj/*
!GameMaster.xcodeproj/project.xcworkspace/
GameMaster.xcodeproj/project.xcworkspace/*
!GameMaster.xcodeproj/project.xcworkspace/xcshareddata/
GameMaster.xcodeproj/project.xcworkspace/xcshareddata/*
!GameMaster.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
GameMaster.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!GameMaster.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Swift Package Manager
.build/
.swiftpm/
.spm-cache/

# Signing / secrets — never commit
*.p8
*.p12
*.cer
*.pem
*.mobileprovision
*.provisionprofile
secrets/
notary-*.json

# Build / release artifacts
dist/
*.dmg
*.zip
*.app

# Code coverage
*.profraw
*.profdata
coverage/

.superpowers/

# Internal engineering notes + marketing assets: a separate local-only git
# repository, intentionally not published.
docs-internal/
