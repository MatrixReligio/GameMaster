    "Remove from Library": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリから削除"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "라이브러리에서 제거"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从程序库移除"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從程式庫移除"
          }
        }
      }
    },
    "Renders at full HiDPI pixel density with matching Windows DPI. Sharper picture, but games draw up to 4× the pixels — turn it off for extra FPS.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "HiDPI のフル解像度でレンダリングし、Windows の DPI を合わせます。画面は鮮明になりますが、描画ピクセルは最大 4 倍になります。FPS を稼ぎたい場合はオフにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "HiDPI 전체 픽셀 밀도로 렌더링하고 Windows DPI를 일치시킵니다. 화면은 더 선명해지지만 게임이 그리는 픽셀이 최대 4배가 됩니다. FPS를 높이려면 끄세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "以完整 HiDPI 像素密度渲染并匹配 Windows DPI。画面更清晰，但游戏渲染的像素最多可达 4 倍——关闭可换取更高帧率。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "以完整 HiDPI 像素密度算繪並匹配 Windows DPI。畫面更清晰，但遊戲算繪的像素最多可達 4 倍——關閉可換取更高幀率。"
          }
        }
      }
    },
    "Retina resolution": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Retina 解像度"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Retina 해상도"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Retina 分辨率"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Retina 解析度"
          }
        }
      }
    },
    "Rosetta 2 is required. Run “softwareupdate --install-rosetta” in Terminal first.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Rosetta 2 が必要です。まずターミナルで “softwareupdate --install-rosetta” を実行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Rosetta 2가 필요합니다. 먼저 터미널에서 “softwareupdate --install-rosetta”를 실행하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要 Rosetta 2。请先在“终端”中运行 “softwareupdate --install-rosetta”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "需要 Rosetta 2。請先在「終端機」中執行 “softwareupdate --install-rosetta”。"
          }
        }
      }
    },
