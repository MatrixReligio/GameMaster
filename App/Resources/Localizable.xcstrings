    "Add to Library and Run": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリに追加して実行"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "라이브러리에 추가 후 실행"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加到程序库并运行"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "加入程式庫並執行"
          }
        }
      }
    },
    "Advanced": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "詳細"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고급"
