    "Create Bottle": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ボトルを作成"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보틀 만들기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建游戏瓶"
          }
        },
        "zh-Hant": {
