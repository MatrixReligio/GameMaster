          }
        }
      }
    },
    "Automatic (recommended)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動（推奨）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동(권장)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动（推荐）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動（建議）"
          }
        }
      }
    },
    "Automatic routes Direct3D through the runtime's D3DMetal layer. Off disables it and falls back to Wine's OpenGL path — only useful for troubleshooting.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「自動」は Direct3D をランタイムの D3DMetal レイヤー経由で変換します。「オフ」はこれを無効化し、Wine の OpenGL パスにフォールバックします。トラブルシューティング専用です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'자동'은 Direct3D를 런타임의 D3DMetal 레이어를 통해 변환합니다. '끄기'는 이를 비활성화하고 Wine의 OpenGL 경로로 대체합니다. 문제 해결 시에만 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「自动」将 Direct3D 经由运行时的 D3DMetal 层转换。「关闭」会禁用它并回退到 Wine 的 OpenGL 路径——仅用于排查问题。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「自動」將 Direct3D 經由執行階段的 D3DMetal 層轉換。「關閉」會停用它並回退到 Wine 的 OpenGL 路徑——僅用於排查問題。"
          }
        }
      }
    },
