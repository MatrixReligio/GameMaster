    "Delete this bottle and everything installed in it?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このボトルと中にインストールされたすべてを削除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보틀과 그 안에 설치된 모든 항목을 삭제할까요?"
          }
        },
