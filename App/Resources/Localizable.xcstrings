          }
        }
      }
    },
    "Automatic (recommended)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動（推奨）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동(권장)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动（推荐）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動（建議）"
          }
        }
      }
    },
    "Automatic routes Direct3D through the runtime's Metal layer (D3DMetal on GPTK runtimes, DXMT otherwise). Off falls back to Wine's OpenGL path — only useful for troubleshooting.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“自动”将 Direct3D 通过运行时自带的 Metal 层转换（GPTK 运行时用 D3DMetal，其余用 DXMT）。“关闭”回退到 Wine 的 OpenGL 路径——仅用于排查问题。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「自動」將 Direct3D 透過執行階段內建的 Metal 層轉換（GPTK 執行階段用 D3DMetal，其餘用 DXMT）。「關閉」回退到 Wine 的 OpenGL 路徑——僅用於排查問題。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「自動」はランタイムの Metal レイヤー（GPTK ランタイムでは D3DMetal、それ以外は DXMT）で Direct3D を変換します。「オフ」は Wine の OpenGL パスにフォールバックします（トラブルシューティング用）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'자동'은 런타임의 Metal 레이어(GPTK 런타임은 D3DMetal, 그 외는 DXMT)로 Direct3D를 변환합니다. '끔'은 Wine의 OpenGL 경로로 대체됩니다(문제 해결용)."
          }
        }
      }
    },
