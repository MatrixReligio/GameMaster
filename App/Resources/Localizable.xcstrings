            "value": "保存"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存"
          }
        }
      }
    },
    "Set up the Windows version of Steam with one click, then install and play your Windows games.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワンクリックで Windows 版 Steam をセットアップし、Windows ゲームをインストールしてプレイ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클릭 한 번으로 Windows용 Steam을 설치하고 Windows 게임을 즐기세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一键装好 Windows 版 Steam，然后安装并畅玩你的 Windows 游戏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一鍵裝好 Windows 版 Steam，然後安裝並暢玩你的 Windows 遊戲。"
          }
        }
      }
    },
    "Show in Finder": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder に表示"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder에서 보기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在访达中显示"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Finder 中顯示"
          }
        }
      }
    },
    "Shows Apple's Metal performance HUD (FPS, GPU time, resolution) over every window in this bottle.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このボトルのすべてのウインドウに Apple の Metal パフォーマンス HUD（FPS、GPU 時間、解像度）を表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보틀의 모든 창 위에 Apple의 Metal 성능 HUD(FPS, GPU 시간, 해상도)를 표시합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此游戏瓶的每个窗口上显示 Apple 的 Metal 性能 HUD（帧率、GPU 耗时、分辨率）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在此遊戲瓶的每個視窗上顯示 Apple 的 Metal 效能 HUD（幀率、GPU 耗時、解析度）。"
          }
        }
      }
    },
    "Skip for Now": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今はスキップ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금은 건너뛰기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时跳过"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "暫時略過"
          }
        }
      }
    },
    "Some bottles have unreadable metadata and are hidden. Their files remain on disk untouched.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部のボトルのメタデータが読み取れないため非表示になっています。ファイルはディスク上にそのまま残っています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일부 보틀의 메타데이터를 읽을 수 없어 숨겨졌습니다. 해당 파일은 디스크에 그대로 남아 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部分游戏瓶的元数据无法读取，已被隐藏。相关文件仍完整保留在磁盘上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "部分遊戲瓶的中繼資料無法讀取，已被隱藏。相關檔案仍完整保留在磁碟上。"
          }
        }
      }
    },
    "Some programs are still running and could not be stopped. They may be waiting for you to confirm something in their window — handle it and try again, or use Force Stop All.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部のプログラムがまだ実行中で、停止できませんでした。ウィンドウ内で何かの確認を待っている可能性があります。対応してからもう一度お試しいただくか、「すべて強制停止」をご利用ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일부 프로그램이 아직 실행 중이어서 중지하지 못했습니다. 창에서 무언가를 확인하기를 기다리고 있을 수 있습니다. 처리한 후 다시 시도하거나 ‘모두 강제 중지’를 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部分程序仍在运行，无法停止。它们可能正在等待你在窗口中进行确认——处理后再试一次，或使用“全部强制停止”。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "部分程式仍在執行，無法停止。它們可能正在等待你在視窗中進行確認——處理後再試一次，或使用「全部強制停止」。"
          }
        }
      }
    },
    "Some runtimes have unreadable metadata and are hidden. Their files remain on disk untouched.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一部のランタイムのメタデータが読み取れないため非表示になっています。ファイルはディスク上にそのまま残っています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일부 런타임의 메타데이터를 읽을 수 없어 숨겨졌습니다. 해당 파일은 디스크에 그대로 남아 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部分运行时的元数据无法读取，已被隐藏。相关文件仍完整保留在磁盘上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "部分執行階段的中繼資料無法讀取，已被隱藏。相關檔案仍完整保留在磁碟上。"
          }
        }
      }
    },
