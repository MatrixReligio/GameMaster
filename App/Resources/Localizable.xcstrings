    "Set up the Windows version of Steam with one click, then install and play your Windows games.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワンクリックで Windows 版 Steam をセットアップし、Windows ゲームをインストールしてプレイ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클릭 한 번으로 Windows용 Steam을 설치하고 Windows 게임을 즐기세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一键装好 Windows 版 Steam，然后安装并畅玩你的 Windows 游戏。"
          }
