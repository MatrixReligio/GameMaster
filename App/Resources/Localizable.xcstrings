    "Create a bottle — a private Windows environment — to install Steam or run Windows games.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ボトル（独立した Windows 環境)を作成して、Steam のインストールや Windows ゲームの実行ができます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보틀(독립된 Windows 환경)을 만들어 Steam을 설치하거나 Windows 게임을 실행하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建一个游戏瓶（独立的 Windows 环境），即可安装 Steam 或运行 Windows 游戏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "建立一個遊戲瓶（獨立的 Windows 環境），即可安裝 Steam 或執行 Windows 遊戲。"
          }
        }
      }
    },
