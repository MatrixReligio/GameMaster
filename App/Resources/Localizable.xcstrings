{
  "sourceLanguage": "en",
  "strings": {
    "%@ could not reach its download servers. Check your network or proxy, then try again.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ はダウンロードサーバーに接続できませんでした。ネットワークまたはプロキシを確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@이(가) 다운로드 서버에 연결할 수 없습니다. 네트워크 또는 프록시를 확인한 후 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 无法连接到其下载服务器。请检查网络或代理后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 無法連接到其下載伺服器。請檢查網路或代理後重試。"
          }
        }
      }
    },
    "%@ did not finish downloading in time. Check your connection and try again.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ のダウンロードが時間内に完了しませんでした。ネットワーク接続を確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@이(가) 제시간에 다운로드를 완료하지 못했습니다. 네트워크 연결을 확인한 후 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 未能在预期时间内完成下载。请检查网络连接后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 未能在預期時間內完成下載。請檢查網路連線後重試。"
          }
        }
      }
    },
    "Add to Library and Run": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリに追加して実行"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "라이브러리에 추가 후 실행"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加到程序库并运行"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "加入程式庫並執行"
          }
        }
      }
    },
    "Advanced": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "詳細"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고급"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高级"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "進階"
          }
        }
      }
    },
    "Advertise AVX support": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AVX サポートをゲームに通知"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "게임에 AVX 지원 알리기"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向游戏公开 AVX 支持"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "向遊戲公開 AVX 支援"
          }
        }
      }
    },
    "Advertises AVX/AVX2 CPU support so games pick their optimized code paths (Rosetta translates AVX on macOS 15+). Disable if a game probes AVX-512 and crashes at launch.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU が AVX/AVX2 をサポートしているとゲームに通知し、最適化されたコードパスを使わせます（macOS 15 以降の Rosetta が AVX を変換）。AVX-512 を検出して起動時にクラッシュするゲームではオフにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "CPU가 AVX/AVX2를 지원한다고 게임에 알려 최적화된 코드 경로를 사용하게 합니다(macOS 15+의 Rosetta가 AVX를 변환). 게임이 AVX-512를 감지해 실행 시 충돌하면 끄세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向游戏声明 CPU 支持 AVX/AVX2，使其启用优化代码路径（macOS 15+ 的 Rosetta 可翻译 AVX）。若游戏探测 AVX-512 导致启动崩溃，请关闭。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "向遊戲聲明 CPU 支援 AVX/AVX2，使其啟用最佳化程式碼路徑（macOS 15+ 的 Rosetta 可轉譯 AVX）。若遊戲偵測 AVX-512 導致啟動當機，請關閉。"
          }
        }
      }
    },
    "Automatic": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동"
          }
        },
        "zh-Hans": {
          "stringUnit": {
