    },
    "Play": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレイ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "플레이"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始游戏"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開始遊戲"
          }
        }
      }
    },
    "Play Windows games on your Mac. GameMaster sets up everything for you — no command line, no configuration files.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac で Windows ゲームをプレイ。GameMaster がすべてをセットアップ — コマンドラインも設定ファイルも不要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac에서 Windows 게임을 즐기세요. GameMaster가 모든 것을 설정해 드립니다 — 명령줄도 설정 파일도 필요 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Mac 上畅玩 Windows 游戏。GameMaster 为你搞定一切——无需命令行，无需配置文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Mac 上暢玩 Windows 遊戲。GameMaster 為你搞定一切——無需命令列，無需設定檔。"
          }
        }
      }
    },
    "Ray tracing (DXR)": {
      "localizations": {
        "ja": {
          "stringUnit": {
