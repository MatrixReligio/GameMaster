    "The %@ installer failed (exit code %@). Please try again.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ のインストーラーが失敗しました（終了コード %@）。もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 설치 프로그램이 실패했습니다(종료 코드 %@). 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 安装程序失败（退出码 %@）。请重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 安裝程式失敗（結束代碼 %@）。請重試。"
          }
        }
      }
    },
    "The %@ installer finished but the program wasn't found. Please try again.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ のインストーラーは終了しましたが、プログラムが見つかりませんでした。もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 설치가 끝났지만 프로그램을 찾을 수 없습니다. 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 安装程序已结束，但未找到安装后的程序。请重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 安裝程式已結束，但未找到安裝後的程式。請重試。"
          }
        }
      }
    },
    "The Windows runtime is not installed yet. Open Settings → Runtime to install it.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows ランタイムがまだインストールされていません。「設定 → ランタイム」からインストールしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows 런타임이 아직 설치되지 않았습니다. '설정 → 런타임'에서 설치하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows 运行时尚未安装。请打开“设置 → 运行时”进行安装。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows 執行階段尚未安裝。請打開「設定 → 執行階段」進行安裝。"
          }
        }
      }
    },
    "The built-in runtime manifest is missing or corrupted.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "内蔵ランタイムマニフェストが見つからないか破損しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내장 런타임 매니페스트가 없거나 손상되었습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内置运行时清单缺失或已损坏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "內建執行階段清單遺失或已損毀。"
          }
        }
      }
    },
    "The disk image did not produce a mountable volume.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディスクイメージからマウント可能なボリュームが得られませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디스크 이미지에서 마운트 가능한 볼륨을 만들지 못했습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "磁盘映像未产生可挂载的卷。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "磁碟映像檔未產生可掛載的卷宗。"
          }
        }
      }
    },
    "The downloaded file failed verification. Please try downloading again.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードしたファイルの検証に失敗しました。もう一度ダウンロードしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드한 파일이 검증에 실패했습니다. 다시 다운로드해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载的文件未通过校验。请重新下载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載的檔案未通過驗證。請重新下載。"
          }
        }
      }
    },
    "The downloaded runtime has an unexpected layout.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードしたランタイムのレイアウトが想定と異なります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드한 런타임의 구조가 예상과 다릅니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载的运行时目录结构异常。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載的執行階段目錄結構異常。"
          }
        }
      }
    },
    "The libraries in this disk image are not signed by Apple, so they were not imported. Download the original from developer.apple.com/download and try again.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このディスクイメージ内のライブラリは Apple によって署名されていないため、読み込まれませんでした。developer.apple.com/download からオリジナルをダウンロードして再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 디스크 이미지의 라이브러리가 Apple 서명이 없어 가져오지 않았습니다. developer.apple.com/download에서 원본을 다운로드한 후 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该磁盘映像中的库未经 Apple 签名，因此未被导入。请从 developer.apple.com/download 下载原版后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該磁碟映像中的程式庫未經 Apple 簽署，因此未被匯入。請從 developer.apple.com/download 下載原版後重試。"
          }
        }
      }
    },
    "This bottle is being installed into. Wait for the install to finish, then delete it.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このボトルにインストール中です。インストールが完了してから削除してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보틀에 설치가 진행 중입니다. 설치가 끝난 후 삭제하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在向这个游戏瓶安装内容。请等安装完成后再删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在向這個遊戲瓶安裝內容。請等安裝完成後再刪除。"
          }
        }
      }
    },
    "This bottle no longer exists on disk.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このボトルはディスク上に存在しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보틀은 더 이상 디스크에 존재하지 않습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此游戏瓶在磁盘上已不存在。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此遊戲瓶在磁碟上已不存在。"
          }
        }
      }
    },
    "This bottle's runtime translates Direct3D to Metal with DXMT, which is built into Wine itself and is always active — that's why there is no Off choice here.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このボトルのランタイムは DXMT で Direct3D を Metal に変換します。DXMT は Wine 本体に組み込まれており常に有効なため、ここに「オフ」の選択肢はありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보틀의 런타임은 DXMT로 Direct3D를 Metal로 변환합니다. DXMT는 Wine 자체에 내장되어 항상 활성화되므로 여기에는 '끄기' 옵션이 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这个游戏瓶的运行时通过 DXMT 将 Direct3D 转换为 Metal。DXMT 内置于 Wine 本体、始终生效——因此这里没有「关闭」选项。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這個遊戲瓶的執行階段透過 DXMT 將 Direct3D 轉換為 Metal。DXMT 內建於 Wine 本體、始終生效——因此這裡沒有「關閉」選項。"
          }
        }
      }
    },
    "This disk image doesn’t look like Apple’s “Evaluation environment for Windows games”. Download it from developer.apple.com/download (search for “Evaluation environment”).": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このディスクイメージは Apple の「Evaluation environment for Windows games」ではないようです。developer.apple.com/download からダウンロードしてください（「Evaluation environment」で検索）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 디스크 이미지는 Apple의 \"Evaluation environment for Windows games\"가 아닌 것 같습니다. developer.apple.com/download에서 다운로드하세요(\"Evaluation environment\" 검색)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此磁盘映像看起来不是 Apple 的“Evaluation environment for Windows games”。请前往 developer.apple.com/download 下载（搜索“Evaluation environment”）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此磁碟映像檔看起來不是 Apple 的「Evaluation environment for Windows games」。請前往 developer.apple.com/download 下載（搜尋「Evaluation environment」）。"
          }
        }
      }
    },
    "Uncapped": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "制限なし"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무제한"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不限"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "不限"
          }
        }
      }
    },
    "Unknown installer.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不明なインストーラーです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "알 수 없는 설치 항목입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未知的安装项。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未知的安裝項目。"
          }
        }
      }
    },
    "Unpacking…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "展開中…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "압축 해제 중…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在解压…"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在解壓…"
          }
        }
      }
    },
    "Update Apple's Graphics Layer (Optional)": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple グラフィックスレイヤーを更新（任意）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 그래픽 레이어 업데이트(선택)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更新 Apple 图形层（可选）"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "更新 Apple 圖形層（可選）"
          }
        }
      }
    },
    "Upgrading runtime…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランタイムをアップグレード中…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "런타임 업그레이드 중…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在升级运行环境…"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在升級執行環境…"
          }
        }
      }
    },
    "Verifying…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検証中…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인 중…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在校验…"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在驗證…"
          }
        }
      }
    },
    "Welcome to GameMaster": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GameMaster へようこそ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GameMaster에 오신 것을 환영합니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "欢迎使用 GameMaster"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "歡迎使用 GameMaster"
          }
        }
      }
    },
    "Windows programs are running in this bottle": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このボトルで Windows プログラムが実行中です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보틀에서 Windows 프로그램이 실행 중입니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这个游戏瓶中有 Windows 程序正在运行"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這個遊戲瓶中有 Windows 程式正在執行"
          }
        }
      }
    },
    "Windows programs are still running in this bottle. Stop them first, then delete it.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このボトルではまだ Windows プログラムが実行中です。先に停止してから削除してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보틀에서 아직 Windows 프로그램이 실행 중입니다. 먼저 중지한 후 삭제하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这个游戏瓶中仍有 Windows 程序在运行。请先停止它们，再删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這個遊戲瓶中仍有 Windows 程式在執行。請先停止它們，再刪除。"
          }
        }
      }
    },
    "Your runtime already includes DirectX 11/12 translation. To update it to Apple's latest version, download “Evaluation environment for Windows games” from Apple (free Apple ID required) and import the DMG here.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランタイムには DirectX 11/12 変換が既に含まれています。Apple の最新版に更新するには、Apple から「Evaluation environment for Windows games」をダウンロードし（無料の Apple ID が必要）、その DMG をここで読み込んでください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "런타임에는 DirectX 11/12 변환이 이미 포함되어 있습니다. Apple 최신 버전으로 업데이트하려면 Apple에서 “Evaluation environment for Windows games”를 다운로드한 후(무료 Apple ID 필요) 여기에서 DMG를 가져오세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的运行时已内置 DirectX 11/12 转换。若要更新到 Apple 最新版本，请从 Apple 下载“Evaluation environment for Windows games”（需要免费 Apple ID），然后在此导入该 DMG。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的執行環境已內建 DirectX 11/12 轉換。若要更新到 Apple 最新版本，請從 Apple 下載「Evaluation environment for Windows games」（需要免費 Apple ID），然後在此匯入該 DMG。"
          }
        }
      }
    },
    "“%@” failed (exit code %@). Check the bottle's logs for details.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」が失敗しました（終了コード %@）。詳細はボトルのログを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"이(가) 실패했습니다(종료 코드 %@). 자세한 내용은 보틀 로그를 확인하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”运行失败（退出码 %@）。详情请查看游戏瓶日志。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」執行失敗（結束代碼 %@）。詳情請查看遊戲瓶日誌。"
          }
        }
      }
    },
    "“%@” will be moved to oblivion. This cannot be undone.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」は完全に削除されます。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”이(가) 영구히 삭제됩니다. 되돌릴 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”将被永久删除。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」將被永久刪除。此操作無法復原。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
